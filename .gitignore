# BMAD framework — installer-generated, reinstalled per machine; only custom/ is tracked
_bmad/*
!_bmad/custom/
# ...but per-machine user configs inside _bmad/custom/ are gitignored (file header says NOT committed)
_bmad/custom/*.user.toml
_bmad/custom/*.user.yaml

# BMAD installer-generated skill copies in source-of-truth dir (mirror to .claude/skills/* covered by wildcard below)
.agents/skills/bmad-*/
.claude/skills/bmad-*/
